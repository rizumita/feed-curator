{
  "name": "feed-curator",
  "version": "0.5.0",
  "description": "Personalized RSS briefings for developers, powered by Claude Code. No API keys needed.",
  "author": "Ryoichi Izumita <r.izumita@caph.jp>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rizumita/feed-curator.git"
  },
  "keywords": [
    "rss",
    "feed",
    "curation",
    "ai",
    "claude-code"
  ],
  "type": "module",
  "bin": {
    "feed-curator": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "DB_PATH=./data/test.db vitest run --no-file-parallelism",
    "build:binary": "bun run scripts/build-binary.ts",
    "build:app": "op run --env-file .env -- cargo tauri build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "commander": "^13.0.0",
    "fast-xml-parser": "^5.0.0"
  },
  "devDependencies": {
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
