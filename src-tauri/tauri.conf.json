{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Feed Curator",
  "version": "0.5.0",
  "identifier": "jp.caph.feed-curator",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Feed Curator",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/feed-curator"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: CAPH TECH Inc. (48Q6C6AAMX)",
      "entitlements": null
    }
  }
}
